{
  "name": "@polymarket/bindings",
  "version": "0.0.0",
  "description": "Internal package. Contains generated bindings for the Polymarket API. Not intended for direct use.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./clob": {
      "types": "./dist/clob/index.d.ts",
      "default": "./dist/clob/index.js"
    },
    "./gamma": {
      "types": "./dist/gamma/index.d.ts",
      "default": "./dist/gamma/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "default": "./dist/data/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "clob": [
        "./dist/clob/index.d.ts"
      ],
      "data": [
        "./dist/data/index.d.ts"
      ],
      "gamma": [
        "./dist/gamma/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "@polymarket/types": "workspace:*",
    "zod": "^4.3.6"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
